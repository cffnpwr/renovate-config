{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "customDatasources": {
    "rust-toolchain": {
      "defaultRegistryUrlTemplate": "https://static.rust-lang.org/dist/channel-rust-nightly.toml",
      "format": "toml",
      "transformTemplates": [
        "{ \"releases\": [{ \"version\": $join([\"nightly-\", body.date]) }] }"
      ]
    }
  },
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["(^|/)rust-toolchain\\.toml$"],
      "matchStrings": [
        "channel\\s*=\\s*\"(?<currentValue>nightly-[0-9]{4}-[0-9]{2}-[0-9]{2})\""
      ],
      "datasourceTemplate": "custom.rust-toolchain",
      "packageNameTemplate": "Rust toolchain",
      "versioningTemplate": "rust-release-channel"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["Rust toolchain"],
      "schedule": "* * 1 * *", // Monthly on the 1st at 00:00
      "commitMessagePrefix": "chore(rust):",
      "commitMessageTopic": "Rust toolchain",
      "groupName": "Rust toolchain",
      "addLabels": ["rust-toolchain"]
    }
  ]
}
